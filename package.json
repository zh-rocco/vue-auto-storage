{
  "name": "vue-auto-storage",
  "version": "2.0.0",
  "description": "An automatic storage plugin for Vue2, persist the data with localStorage.",
  "main": "dist/index.js",
  "typings": "types/index.d.ts",
  "scripts": {
    "dev": "vue-cli-service serve",
    "build": "rimraf dist && cross-env NODE_ENV=production rollup -c scripts/rollup.config.prod.js",
    "build:docs": "rimraf docs && vue-cli-service build",
    "test": "cross-env NODE_ENV=test jest",
    "deploy": "npm run test && npm run build:lib && npm run build:docs"
  },
  "files": [
    "README.md",
    "src",
    "dist/*.js",
    "types/*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zh-rocco/vue-auto-storage.git"
  },
  "keywords": [
    "vue-auto-storage",
    "auto-storage",
    "persistence",
    "persistent-storage",
    "vue-plugin",
    "vue"
  ],
  "author": {
    "name": "Rocco Mormont",
    "email": "rocco.mormont@gmail.com",
    "url": "https://zh-rocco.github.io/"
  },
  "bugs": {
    "url": "https://github.com/zh-rocco/vue-auto-storage/issues"
  },
  "engines": {
    "node": ">=8"
  },
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {},
  "jest": {
    "clearMocks": true,
    "testURL": "http://localhost",
    "transformIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/dist/"
    ],
    "verbose": true
  }
}

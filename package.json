{
  "name": "vue-auto-storage",
  "version": "2.0.0",
  "description": "An automatic storage plugin for Vue2, persist the data with localStorage.",
  "main": "dist/index.js",
  "typings": "types/index.d.ts",
  "scripts": {
    "dev": "vue-cli-service serve",
    "build": "rimraf dist && tsc",
    "build:docs": "rimraf docs && vue-cli-service build",
    "test": "jest",
    "deploy": "npm run test && npm run build && npm run build:docs"
  },
  "files": [
    "README.md",
    "src",
    "dist/*.js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zh-rocco/vue-auto-storage.git"
  },
  "keywords": [
    "vue-auto-storage",
    "auto-storage",
    "persistence",
    "persistent-storage",
    "vue-plugin",
    "vue"
  ],
  "author": {
    "name": "Rocco Mormont",
    "email": "rocco.mormont@gmail.com",
    "url": "https://zh-rocco.github.io/"
  },
  "bugs": {
    "url": "https://github.com/zh-rocco/vue-auto-storage/issues"
  },
  "engines": {
    "node": ">=8"
  },
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^23.3.11",
    "jest": "^23.6.0",
    "ts-jest": "^23.10.5",
    "tslint": "^5.12.0",
    "typescript": "^3.2.2",
    "vue": "^2.5.21"
  }
}
